{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "deno fmt 2>/dev/null; git add -u 2>/dev/null; true",
            "timeout": 30,
            "statusMessage": "Formatting with deno fmt..."
          }
        ]
      }
    ]
  }
}
