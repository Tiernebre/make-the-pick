{
  "workspace": ["./packages/shared", "./server", "./client"],
  "nodeModulesDir": "auto",
  "fmt": {
    "useTabs": false,
    "indentWidth": 2,
    "singleQuote": false
  },
  "tasks": {
    "setup": "test -f .env || cp .env.example .env && deno install",
    "dev": "deno task setup && deno task db:start; deno run -A npm:concurrently -n server,client -c blue,green \"deno task dev:server\" \"deno task dev:client\"",
    "dev:server": "cd server && deno run --allow-net --allow-env --allow-read --env main.ts",
    "dev:client": "cd client && deno run -A npm:vite",
    "test": "deno task test:server && deno task test:client",
    "test:server": "deno test server/ --allow-env --allow-net --allow-read --env=.env.example",
    "test:client": "cd client && deno run -A npm:vitest run",
    "build": "cd client && deno task build",
    "start": "cd server && deno run --allow-net --allow-env --allow-read --env main.ts",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "concurrently": "npm:concurrently@^9.2.1"
  },
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
