{
  "workspace": ["./packages/shared", "./server", "./client"],
  "nodeModulesDir": "auto",
  "fmt": {
    "useTabs": false,
    "indentWidth": 2,
    "singleQuote": false
  },
  "tasks": {
    "dev": "deno task dev:server & deno task dev:client",
    "dev:server": "cd server && deno run --allow-net --allow-env --allow-read --env main.ts",
    "dev:client": "cd client && deno run -A npm:vite",
    "test": "deno task test:server && deno task test:client",
    "test:server": "deno test server/ --allow-env --allow-net --allow-read --env",
    "test:client": "cd client && deno run -A npm:vitest run",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down"
  },
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
